{
  "name": "proptech-valuation-drift-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Board-readable PropTech valuation drift monitor across comps, rent roll, cap-rate, and listing evidence.",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "demo": "tsx scripts/run_demo.ts",
    "python:test": "python -m unittest discover -s python -p \"*_test.py\"",
    "sql:check": "tsx scripts/check_sql.ts",
    "prerender": "tsx scripts/prerender.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run demo && npm run python:test && npm run sql:check && npm run prerender && npm run smoke"
  },
  "keywords": [
    "proptech",
    "valuation",
    "real-estate",
    "drift-monitor",
    "rent-roll",
    "cap-rate"
  ],
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.1.8"
  }
}
